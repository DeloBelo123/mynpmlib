{
  "extends": "../tsconfig.json",
    "compilerOptions": {
      "outDir": "dist",
    "rootDir": "src",
    "moduleResolution": "bundler",
      "resolveJsonModule": true,
      "skipLibCheck": true,
      "types": ["node"]
    },
  "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist", "*.db", "*.sqlite", "sqlite-test"]
  }
  

